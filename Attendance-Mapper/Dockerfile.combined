# ─── Stage 1: Build API ────────────────────────────────────────────────────────
FROM node:20-alpine AS api-builder

RUN corepack enable && corepack prepare pnpm@latest --activate
WORKDIR /app

COPY package.json pnpm-workspace.yaml tsconfig.base.json ./
COPY lib/db/package.json ./lib/db/
COPY lib/api-zod/package.json ./lib/api-zod/
COPY artifacts/api-server/package.json ./artifacts/api-server/

RUN pnpm install --no-frozen-lockfile

COPY lib/db/ ./lib/db/
COPY lib/api-zod/ ./lib/api-zod/
COPY artifacts/api-server/ ./artifacts/api-server/

RUN pnpm --filter @workspace/api-server build

# ─── Stage 2: Build Frontend ───────────────────────────────────────────────────
FROM node:20-slim AS frontend-builder

RUN corepack enable && corepack prepare pnpm@latest --activate
WORKDIR /app

COPY . .

# Fix catalog: references
RUN node -e "const fs=require('fs');const catalog={'drizzle-orm':'^0.39.0','@types/node':'^22.0.0','@tailwindcss/vite':'^4.0.0','@tanstack/react-query':'^5.0.0','@types/react':'^19.0.0','@types/react-dom':'^19.0.0','@vitejs/plugin-react':'^4.0.0','class-variance-authority':'^0.7.0','clsx':'^2.0.0','framer-motion':'^11.0.0','lucide-react':'^0.383.0','react':'^19.0.0','react-dom':'^19.0.0','tailwind-merge':'^2.0.0','tailwindcss':'^4.0.0','vite':'^6.0.0','zod':'^3.24.0','@replit/vite-plugin-cartographer':null,'@replit/vite-plugin-dev-banner':null,'@replit/vite-plugin-runtime-error-modal':null};const {execSync}=require('child_process');const files=execSync('find /app -maxdepth 5 -name \"package.json\" -not -path \"*/node_modules/*\"').toString().trim().split('\n');for(const f of files){try{const pkg=JSON.parse(fs.readFileSync(f,'utf8'));let changed=false;for(const s of['dependencies','devDependencies']){if(!pkg[s])continue;for(const[k,v]of Object.entries(pkg[s])){if(v==='catalog:'){if(catalog[k]===null){delete pkg[s][k];changed=true;}else if(catalog[k]){pkg[s][k]=catalog[k];changed=true;}}}}if(changed){fs.writeFileSync(f,JSON.stringify(pkg,null,2));console.log('Fixed: '+f);}}catch(e){}}"

# Fix vite config
RUN node -e "const fs=require('fs'),{execSync}=require('child_process');const cfg='import{defineConfig}from\"vite\";import react from\"@vitejs/plugin-react\";import tailwindcss from\"@tailwindcss/vite\";import p from\"path\";export default defineConfig({plugins:[react(),tailwindcss()],resolve:{alias:{\"@\":p.resolve(__dirname,\"./src\")}},server:{host:\"0.0.0.0\",port:5173}});';const files=execSync('find /app -maxdepth 6 -name \"vite.config.ts\" -not -path \"*/node_modules/*\"').toString().trim().split('\n').filter(Boolean);for(const f of files){fs.writeFileSync(f,cfg);console.log('Overwrote: '+f);}"

RUN node -e "const fs=require('fs'),{execSync}=require('child_process');const files=execSync('find /app -maxdepth 4 -name \"pnpm-workspace.yaml\"').toString().trim().split('\n').filter(Boolean);if(!files.length){console.error('No pnpm-workspace.yaml found!');process.exit(1);}const root=require('path').dirname(files[0]);console.log('Workspace root: '+root);fs.writeFileSync('/workspace-root',root);"
RUN cd $(cat /workspace-root) && pnpm install --no-frozen-lockfile

# Build frontend with /api as the API URL (relative — nginx handles it)
RUN cd $(cat /workspace-root) && VITE_API_URL=/api pnpm --filter @workspace/attendance-mapper build

# ─── Stage 3: Combined runtime ─────────────────────────────────────────────────
FROM node:20-alpine AS runner

# Install nginx and supervisor (supervisor starts both nginx + node)
RUN apk add --no-cache nginx supervisor

WORKDIR /app

# Copy built API
COPY --from=api-builder /app/artifacts/api-server/dist ./dist

# Copy frontend build into nginx html dir
COPY --from=frontend-builder /app/artifacts/attendance-mapper/dist /usr/share/nginx/html

# Copy nginx config (hardcoded to proxy /api → localhost:3000)
COPY nginx.combined.conf /etc/nginx/http.d/default.conf

# Supervisor config to run both processes
COPY supervisord.conf /etc/supervisord.conf

ENV NODE_ENV=production
ENV PORT=3000

EXPOSE 80

CMD ["/usr/bin/supervisord", "-c", "/etc/supervisord.conf"]
